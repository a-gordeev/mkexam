# ── LLM backend: "gemini" (default) or "openai" ──────────────────────────────
# LLM_BACKEND=gemini

# ── Gemini (used when LLM_BACKEND=gemini) ────────────────────────────────────
GEMINI_API_KEY=your_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI-compatible (used when LLM_BACKEND=openai) ─────────────────────────
# OPENAI_BASE_URL=https://llm.ai.e-infra.cz/v1/
# OPENAI_API_KEY=your_api_key_here
# OPENAI_MODEL=llama-3.3-70b-instruct
