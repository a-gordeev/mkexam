# ── LLM backend ──────────────────────────────────────────────────────────────
# Choose: "gemini" (cloud, requires API key) or "ollama" (local, no API key)
LLM_BACKEND=ollama

# ── Gemini (used when LLM_BACKEND=gemini) ────────────────────────────────────
# GEMINI_API_KEY=your_api_key_here

# ── Ollama (used when LLM_BACKEND=ollama) ────────────────────────────────────
# Install Ollama from https://ollama.com, then run: ollama pull gemma3:27b
# OLLAMA_MODEL=gemma3:27b
# OLLAMA_BASE_URL=http://localhost:11434
